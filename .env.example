# Site URL (Twitch embed parent domain + canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
ADMIN_EMAIL_WHITELIST=
ADMIN_PASSWORD=

# Sanity (set USE_SANITY_ROSTER=true to load roster from CMS instead of lib/data/streamers.mock.ts)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
USE_SANITY_ROSTER=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=

# Twitch Helix API
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube Data API (optional — scaffold only)
YOUTUBE_API_KEY=
